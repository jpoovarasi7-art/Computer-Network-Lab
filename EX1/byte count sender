void processFileInput(char filename[],char srcUrl[],char destUrl[])
 {
    int ch, i;
    printf("\nEnter filename: ");
    scanf("%s", filename);
    FILE *f = fopen(filename, "r");
    if (!f) {
        printf("[-] Error: File '%s' not found!\n", filename);
        dataLength = -1;
        return;
    }
    dataLength = 0;
    while ((ch = fgetc(f)) != EOF && dataLength < File_Size - 1) {
        fileData[dataLength++] = (char)ch;
    }
    fileData[dataLength] = '\0';
    fclose(f);
    if (dataLength > 0 && fileData[dataLength - 1] == '\n') {
        fileData[--dataLength] = '\0';
    }
    Tcp_network_layer(srcUrl, destUrl);
    printf("******************SENDER PART*******************\n");
    printf("\nDATA BEFORE STUFFING\n");
    printf("-------------------------------------\n");
    printf("%s\n",fileData);
    printf("-------------------------------------\n");
    printf("\nDATA AFTER STUFFING\n");
    printf("-------------------------------------\n");
    Data_stuffing(fileData);
    printf("\n-------------------------------------\n");
}
