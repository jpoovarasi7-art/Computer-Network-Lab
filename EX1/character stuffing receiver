int binary_char(char input[])
{
        int i=0,result=0;
        for(i=0;i<8;i++)
        {
                result = (result * 2) + (input[i]-'0');
        }
        return result;
}
void Data_unstuffing()
{
        char sample[]= " ";
        file_opening();
        int skip_dle = 0;
        char word[500] = "";
        char bword[500] = "";
        or_data[0] = '\0';
        b_data[0] = '\0';
    char *sub = strtok(filecontent,sample);
    while(sub!=NULL)
    {
        char content = binary_char(sub);
        strcat(bword,sub);
        strcat(bword," ");
        if(content==' ')
        {
                if(strlen(word)>0)
                {
                        if(strcmp(word,"DLE")==0)
                        {
                                if(skip_dle==1)
                                {
                                        strcat(or_data,word);
                                        strcat(or_data," ");
                                        strcat(b_data,bword);
                                        strcat(b_data," ");
                                        skip_dle=0;
                                }
                                else{
                                        skip_dle=1;
                                }
                        }
                        else{
                                strcat(or_data,word);
                                strcat(or_data," ");
                                strcat(b_data,bword);
                                strcat(b_data," ");
                                skip_dle=0;}
                }
                word[0]='\0';
                bword[0]='\0';
        }
        else{
        	int len = strlen(word);
        	word[len]=content;
        	word[len+1]='\0';
		}
        sub = strtok(NULL,sample);
        }
}
