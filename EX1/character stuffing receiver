#include <stdio.h>
#include <string.h>
#include<stdlib.h>
#define Max_URL 50
#define Max_IP 16
#define Max_MAC 18
#define Hash_Size 10
#define File_Size 1000
#define Max_Choice 15
struct HashEntry {
    char url[Max_URL];
    char ip[Max_IP];
    char mac[Max_MAC];
    int port;
    int is_occupied;
};
struct HashEntry hashTable[Hash_Size];
char fileData[File_Size];
char outname[File_Size];
int dataLength = 0;
int srcIdx = -1;
int destIdx = -1;
char filecontent[File_Size*10] = " ";
char or_data[File_Size]= " ";
char b_data[File_Size*10] = " ";
int getHashIndex(char url[Max_URL]) {
    int sum = 0, i;
    for (i = 0; url[i] != '\0'; i++) sum += url[i];
    return sum % Hash_Size;
}
int getRandomPort() {
    return 1024 + (rand() % (49151 - 1024 + 1));
}
void insertNode(char url[Max_URL], char ip[Max_IP], char mac[Max_MAC], int port) {
    int index = getHashIndex(url), or_index = index;
    while (hashTable[index].is_occupied == 1) {
        if (strcmp(hashTable[index].url, url) == 0) {
            strcpy(hashTable[index].ip, ip);
            strcpy(hashTable[index].mac, mac);
            hashTable[index].port = port;
            return;
        }
        index = (index + 1) % Hash_Size;
        if (index == or_index) return;
    }
    strcpy(hashTable[index].url, url);
    strcpy(hashTable[index].ip, ip);
    strcpy(hashTable[index].mac, mac);
    hashTable[index].port = port;
    hashTable[index].is_occupied = 1;
}
int searchTable(char url[Max_URL]) {
    int index = getHashIndex(url), or_index = index;
    while (hashTable[index].is_occupied != 0) {
        if (strcmp(hashTable[index].url, url) == 0) return index;
        index = (index + 1) % Hash_Size;
        if (index == or_index) break;
    }
    return -1;
}
void printTable() {
    int i;
    printf("\n=================== CURRENT HASH TABLE ===================\n");
    printf("%-6s | %-18s | %-15s | %-17s | %-6s\n", "Index", "URL Link", "IP Address", "MAC Address", "Port");
    printf("----------------------------------------------------------------------\n");
    for (i = 0; i < Hash_Size; i++) {
        if (hashTable[i].is_occupied)
            printf("%-6d | %-18s | %-15s | %-17s | %-6d\n", i, hashTable[i].url, hashTable[i].ip, hashTable[i].mac, hashTable[i].port);
        else
            printf("%-6d | %-18s | %-15s | %-17s | %-6s\n", i, "Empty", "-", "-", "-");
    }
    printf("======================================================================\n");
}
void Char_binary(char ch) {
    int i;
    for (i = 7; i >= 0; i--)
                 printf("%d", (ch >> i) & 1);
}
void String_binary(char *str) {
    int i;
    for (i = 0; str[i] != '\0'; i++) {
        Char_binary(str[i]);
        printf(" ");
    }
}
void Ip_binary(char ip[Max_IP]) {
    int v1, v2, v3, v4, p, i;
    int pieces[4];
    if (sscanf(ip, "%d.%d.%d.%d", &v1, &v2, &v3, &v4) != 4)
                return;
    pieces[0] = v1;
        pieces[1] = v2;
        pieces[2] = v3;
        pieces[3] = v4;
    for (p = 0; p < 4; p++) {
        for (i = 7; i >= 0; i--)
                        printf("%d", (pieces[p] >> i) & 1);
        printf(" ");
    }
}
void Mac_binary(char mac[Max_MAC]) {
    unsigned int m1, m2, m3, m4;
    int p, i;
    unsigned int pieces[4];
    if (sscanf(mac, "%x:%x:%x:%x", &m1, &m2, &m3, &m4) != 4)
                return;
    pieces[0] = m1;
        pieces[1] = m2;
        pieces[2] = m3;
        pieces[3] = m4;
    for (p = 0; p < 4; p++) {
        for (i = 7; i >= 0; i--)
                        printf("%d", (pieces[p] >> i) & 1);
        printf(" ");
    }
}
void Port_binary(int port) {
    int i;
    for (i = 15; i >= 0; i--) {
        printf("%d", (port >> i) & 1);
        if (i == 8)
                        printf(" ");
    }
    printf(" ");
}
void Network_table(char choice[], char url[Max_URL], char ip[Max_IP], char mac[Max_MAC]) {
    int count = 1, idx, portnumber;
    while (1) {
        printTable();
        printf("\nModify table? (insert/delete/no): ");
        scanf("%s", choice);
        if (strcmp(choice, "insert") == 0) {
            printf("Enter URL: ");
            scanf("%s", url);
            printf("Enter IP Address: ");
            scanf("%s", ip);
            printf("Enter Mac Address: ");
            scanf("%s", mac);
            portnumber = getRandomPort();
            insertNode(url, ip, mac, portnumber);
            printf("Inserted node successfully. Port: %d\n", portnumber);
        }
        else if (strcmp(choice, "delete") == 0) {
            printf("Enter URL to delete: ");
            scanf("%s", url);
            idx = searchTable(url);
            if (idx != -1) {
                hashTable[idx].is_occupied = 0;
                printf("Deleted entry node for: %s\n", url);
            } else {
                printf("Error: URL '%s' not found!\n", url);
            }
        }
        else if (strcmp(choice, "no") == 0)
                        break;
        else
                        printf("Error: Invalid menu choice.\n");
    }
}
void Tcp_network_layer(char srcUrl[], char destUrl[]) {
    while (1) {
        printf("\nEnter Source URL: ");
        scanf("%s", srcUrl);
        srcIdx = searchTable(srcUrl);
        if (srcIdx != -1)
                        break;
        printf("Error: Source URL '%s' not found. Try again.\n", srcUrl);
    }
    while (1) {
        printf("Enter Destination URL: ");
        scanf("%s", destUrl);
        destIdx = searchTable(destUrl);
        if (destIdx != -1)
                        break;
        printf("Error: Destination URL '%s' not found. Try again.\n", destUrl);
    }
}
