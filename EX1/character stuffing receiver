}
void Network_packets(int packet_size, int frame_size) {
	int packet_char = packet_size / 8;
    if (packet_char <= 0) 
		packet_char = 1;
    int frame_char = frame_size / 8;
    if (frame_char <= 0)
		frame_char = 1;
    int totalPackets = (dataLength + packet_char - 1) / packet_char;
    int i, p, f;
    printf("\n======================================================\n");
    printf("                TCP / IP NETWORK LAYER                  \n");
    printf("======================================================\n");
    printf("\n   L5 - APPLICATION LAYER\n");
	Data_unstuffing_char();
	Data_unstuffing_binary();
    printf("\n------------------------------------------------------\n");
    printf("\n   L4 - TRANSPORT LAYER   \n");
    printf("Ports: %d -> %d\n", hashTable[srcIdx].port, hashTable[destIdx].port);
    printf("Bits : "); 
	Port_binary(hashTable[srcIdx].port);
	printf("-> ");
	Port_binary(hashTable[destIdx].port);
    printf("\nLayer 5: ");
    for (i = 0; i < dataLength; i++) { 
		Char_binary(fileData[i]);
		printf(" "); 
		}
    printf("\n------------------------------------------------------\n");
    printf("\n   L3 - NETWORK LAYER   \n");
    printf("URLs: %s -> %s\n", hashTable[srcIdx].url, hashTable[destIdx].url);
    printf("Src URL: "); 
	String_binary(hashTable[srcIdx].url);
    printf("\nDst URL: "); 
	String_binary(hashTable[destIdx].url);
    printf("\nIPs: %s -> %s\n", hashTable[srcIdx].ip, hashTable[destIdx].ip);
    printf("Src IP: "); 
	Ip_binary(hashTable[srcIdx].ip);
    printf("\nDst IP: "); 
	Ip_binary(hashTable[destIdx].ip);
    for (p = 0; p < totalPackets; p++) {
        int p_start = p * packet_char;
        int p_end = p_start + packet_char;
        if (p_end > dataLength) 
			p_end = dataLength;      
		printf("Total Packet Datagram is %d\n",totalPackets);
        printf("\n Packet Datagram %d:<<\n", p + 1);
        printf("Layer 4 Header bits: ");
		Port_binary(hashTable[srcIdx].port); 
		Port_binary(hashTable[destIdx].port);
        printf("\nLayer 5:");
        for (i = p_start; i < p_end; i++) {
            Char_binary(fileData[i]);
            printf(" ");
        }
        printf("\n");
    }
    printf("------------------------------------------------------\n");
    printf("\nL2 - DATA LINK LAYER\n");
    for (p = 0; p < totalPackets; p++) {
        int p_start = p * packet_char;
        int p_end = p_start + packet_char;
        int frames = (packet_char + frame_char - 1) / frame_char;
        printf("\n Packet %d \n", p + 1);
        for (f = 0; f < frames; f++) {
            int f_start = p_start + (f * frame_char);
            printf("  Frame Segment %d:\n", f + 1);
            printf("MACs: %s -> %s\n", hashTable[srcIdx].mac, hashTable[destIdx].mac);
            printf("Src: "); 
			Mac_binary(hashTable[srcIdx].mac);
            printf("\nDst: "); 
			Mac_binary(hashTable[destIdx].mac);
            printf("\n L3 Header bits: "); 
			String_binary(hashTable[srcIdx].url);
			String_binary(hashTable[destIdx].url); 
			Ip_binary(hashTable[srcIdx].ip); 
			Ip_binary(hashTable[destIdx].ip);
            printf("\n L4 Header bits: "); 
			Port_binary(hashTable[srcIdx].port);
			Port_binary(hashTable[destIdx].port);
            printf("\n    [Encapsulated Frame Payload] : ");
            for (i = 0; i < frame_char; i++) {
                int currIdx = f_start + i;
                if (currIdx < dataLength && currIdx < p_end) {
                    Char_binary(fileData[currIdx]);
                } else {
                    Char_binary(0);
                }
                printf(" ");
            }
            printf("(");
            for (i = 0; i < frame_char; i++) {
                int currIdx = f_start + i;
                if (currIdx < dataLength && currIdx < p_end) {
                    printf("%c", fileData[currIdx]);}
		else {
			printf("");
		     }
	     }
	    printf(")\n");
	    printf("Parity Frame Check Value:00000000\n");
	   }
	}
	printf("\n**********************************************************\n");
    printf("                CHARACTER/BYTE ORIENTED STUFFING                 \n");
    printf("************************************************************\n");
    printf("SYN : 00010110\n");
    printf("SYN : 00010110\n");
    printf("SOH : 00000001\n");
    printf("HEADER : ");
    String_binary(hashTable[destIdx].url);
        String_binary(hashTable[srcIdx].url);
        Mac_binary(hashTable[destIdx].mac);
        Mac_binary(hashTable[srcIdx].mac);
        Ip_binary(hashTable[srcIdx].ip);
        Port_binary(hashTable[srcIdx].port);
    printf("\nSTX : 00000010\n");
    Data_unstuffing_binary();
    printf("\nETX : 00000011\n");
    printf("CRC : 0000000000000000\n");
        printf("************************************************************\n");
        printf("             SYSTEM EXECUTION COMPLETE            \n");
        printf("************************************************************\n");
	printf("------------------------------------------------------\n");
	printf("\n[L1 - PHYSICAL LAYER]\n");
	printf("Complete String Pipeline(8-Bit Layers Segments):\n  ");
	String_binary(hashTable[destIdx].url);
	String_binary(hashTable[srcIdx].url);
	Mac_binary(hashTable[destIdx].mac);
	Mac_binary(hashTable[srcIdx].mac);
	Ip_binary(hashTable[srcIdx].ip);
	Port_binary(hashTable[srcIdx].port);
	for (p = 0; p < totalPackets; p++) {
		int p_start = p * packet_char;
		int frames = (packet_char + frame_char - 1) / frame_char;
		int padding = frames * frame_char;
		for (i = 0; i < padding; i++) {
			int currIdx = p_start + i;
			if (currIdx < dataLength && currIdx < (p_start + packet_char)) {
				Char_binary(fileData[currIdx]);
			} 
			else {
				Char_binary(0);
			}
			printf(" ");
		}
	}
	printf("00000000\n");
	printf("00010110");
    printf("00010110");
    printf("00000001");
    printf("00000010");
    Data_unstuffing_char();
	Data_unstuffing_binary();
    printf("00000011");
    printf("0000000000000000");
	printf("======================================================\n");
	printf("             SYSTEM EXECUTION COMPLETE            \n");
	printf("======================================================\n");
}
